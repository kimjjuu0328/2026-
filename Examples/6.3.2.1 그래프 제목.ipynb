   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "data=np.random.random(10) #10개의 랜덤 값을 가진 1차원 ndarray 생성\n",
    "plt.title(\"stock prices\") #그래프에 대한 제목 지정 \n",
    "plt.plot(data) #선형 그래프로 출력\n",
    "plt.show()"
   ]
  }
