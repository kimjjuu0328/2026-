   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "x =  np.arange(4).reshape(2,2) #Numpy의 ndarray을 0 부터 3까지로 채워 생성하고 2,2 형태로 변형\n",
    "print(x)\n",
    "y =  np.arange(3,-1,-1).reshape(2,2) #Numpy의 ndarray을 3 부터 0까지로 채워 생성하고 2,2 형태로 변형\n",
    "print(y)\n",
    "\n",
    "s1 =  np.matmul(x,y) #ndarray x와 y를 행렬곱하여 반환\n",
    "print(s1)"
   ]
  }
